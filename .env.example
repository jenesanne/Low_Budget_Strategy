# Alpaca API credentials — fill in your own keys
# Get them from https://app.alpaca.markets/ → Paper Trading → API Keys
# NEVER commit real keys to version control.

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to "paper" for paper trading, "live" for real money
ALPACA_ENVIRONMENT=paper

# Alpha Vantage API key
# Get your free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=your_password_here
